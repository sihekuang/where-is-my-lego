{
  "name": "where-is-my-lego-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Read-only interactive site for the where-is-my-lego archive. Reads data derived from the canonical root Markdown.",
  "scripts": {
    "derive": "node scripts/derive-data.mjs",
    "predev": "npm run derive",
    "dev": "next dev",
    "prebuild": "npm run derive && npm run translate:check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "translate": "node scripts/translate.mjs",
    "translate:check": "node scripts/translate.mjs --check",
    "test": "node scripts/derive-data.test.mjs && node scripts/og-image.test.mjs && node scripts/check-ui.test.mjs && node scripts/minifig.test.mjs && node scripts/translate.test.mjs && node scripts/i18n-ui.test.mjs && node scripts/overlay.test.mjs && node scripts/glossary.test.mjs && node scripts/links.test.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/cytoscape": "^3.31.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3"
  }
}
