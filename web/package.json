{
  "name": "bam-scandal-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Read-only interactive site for the bam-scandal archive. Reads data derived from the canonical root Markdown.",
  "scripts": {
    "derive": "node scripts/derive-data.mjs",
    "predev": "npm run derive",
    "dev": "next dev",
    "prebuild": "npm run derive",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node scripts/derive-data.test.mjs && node scripts/og-image.test.mjs"
  },
  "dependencies": {
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.31.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "typescript": "6.0.3"
  }
}
